#
# Feature definitions
#

feature calt { # 连锁上下文替换
    script DFLT; # 默认
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script latn; # 拉丁语
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script arab; # 阿拉伯语
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script armn; # 亚美尼亚语
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script bopo; # 汉语拼音
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script brai; # 婆罗米语
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script copt; # 科普特语
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script cyrl; # 西里尔文
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script grek; # 希腊语
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script hang; # 谚文
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script hani; # 中日韩汉字
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script hebr; # 希伯来语
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script kana; # 日本语平假名
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script math; # 数学文字符号
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script musc; # 音乐符号
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script ogam; # 欧甘语
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script plrd; # 苗语
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script runr; # 古北欧文
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script thai; # 泰语
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;

    script tibt; # 藏语
        lookup 被连锁的上下文替换1;
        lookup 被连锁的上下文替换9;
} calt;

feature lnum { # 齐线数字
    script DFLT; # 默认
        lookup 单字形替换16;

    script latn; # 拉丁语
        lookup 单字形替换16;
        language ANG exclude_dflt; # 盎格鲁撒克逊语

    script bali; # 巴厘语
        lookup 单字形替换16;

    script brai; # 婆罗米语
        lookup 单字形替换16;

    script cyrl; # 西里尔文
        lookup 单字形替换16;

    script grek; # 希腊语
        lookup 单字形替换16;

    script hani; # 中日韩汉字
        lookup 单字形替换16;
        language ZHS exclude_dflt; # 中文简体

    script hebr; # 希伯来语
        lookup 单字形替换16;

    script kana; # 日本语平假名
        lookup 单字形替换16;

    script ogam; # 欧甘语
        lookup 单字形替换16;

    script runr; # 古北欧文
        lookup 单字形替换16;

    script tibt; # 藏语
        lookup 单字形替换16;
} lnum;

feature locl { # 本地化样式
    script latn; # 拉丁语
        language ANG; # 盎格鲁撒克逊语
            sub Thorn by Thorn.anglisc;
            sub eth by eth.anglisc;
            sub thorn by thorn.anglisc;

    script arab; # 阿拉伯语
        language URD; # 乌尔都语
            sub extendedarabicindicfour-arabic by extendedarabicindicfour-arabic.var;
            sub extendedarabicindicseven-arabic by extendedarabicindicseven-arabic.var;
} locl;

