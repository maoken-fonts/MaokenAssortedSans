feature frac { # 函数
    script latn; # 拉丁语
        sub zero slash three by zerothirds;
        sub zero fraction three by zerothirds;
        sub one slash one zero by onetenth;
        sub one fraction one zero by onetenth;
        sub one slash one by one_slash_one.frac;
        sub one slash two by onehalf;
        sub one slash three by onethird;
        sub one slash four by onequarter;
        sub one slash five by onefifth;
        sub one slash six by onesixth;
        sub one slash seven by oneseventh;
